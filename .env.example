# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hostpanel:hostpanel@localhost:5432/hostpanel"

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API ───────────────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
JWT_SECRET="change-me-in-production-min-32-chars"
# Comma-separated allowed origins for CORS. Leave unset to allow all (dev only).
# Example for LAN access: CORS_ORIGIN="http://192.168.1.50:3000,http://localhost:3000"
CORS_ORIGIN=""

# ─── CrowdSec ──────────────────────────────────────────────────────────────────
# Get key from: sudo cscli bouncers add hostpanel-api
CROWDSEC_API_URL="http://127.0.0.1:8080"
CROWDSEC_API_KEY=""
JWT_REFRESH_SECRET="change-me-refresh-min-32-chars"
SESSION_SECRET="change-me-session-min-32-chars"

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-nextauth-secret"

# ─── OAuth ─────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── SSL / Let's Encrypt ────────────────────────────────────────────────────────
ACME_EMAIL="admin@example.com"
ACME_STAGING=true

# ─── Integrations ──────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=""
SLACK_WEBHOOK_URL=""
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""

# ─── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@localhost"
ADMIN_PASSWORD="change-me"
