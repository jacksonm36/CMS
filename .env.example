# Copy to .env and replace secrets — production installs generate these via install.sh
# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hostpanel:hostpanel@localhost:5432/hostpanel"

# Auto-run prisma migrate deploy on API startup when NODE_ENV=production (omit or false for local dev)
HOSTPANEL_AUTO_MIGRATE=false

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API ───────────────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
# Optional: max JSON body size in bytes (default 2097152 = 2 MiB)
# HOSTPANEL_API_BODY_LIMIT_BYTES=2097152
# Optional: global REST baseline (per IP per minute). Per-route limits (e.g. login) are stricter. Default 200.
# HOSTPANEL_GLOBAL_RATE_LIMIT_MAX=200
# Optional: block site file manager access to multiply-hardlinked regular files (same-FS hardlink edge case). Default off.
# HOSTPANEL_SITE_FILES_BLOCK_HLINKS=false
JWT_SECRET="change-me-in-production-min-32-chars"
# Comma-separated allowed browser origins for CORS (must match the URL you type in the address bar).
# Local dev: include the web UI origin(s). Production: REQUIRED — the API will not start without this when NODE_ENV=production.
# Example: CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"
# LAN: CORS_ORIGIN="http://192.168.1.50:3000"
# HTTPS: CORS_ORIGIN="https://panel.example.com"
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"

# Optional: allow site cron strings to use sudo/apt/systemctl (NOT recommended — hostpanel sudoers allow apt/nginx reload for the panel).
# HOSTPANEL_CRON_ALLOW_PRIVILEGED_COMMANDS=false

# ─── CrowdSec ──────────────────────────────────────────────────────────────────
# Get key from: sudo cscli bouncers add hostpanel-api
CROWDSEC_API_URL="http://127.0.0.1:8080"
CROWDSEC_API_KEY=""
JWT_REFRESH_SECRET="change-me-refresh-min-32-chars"
SESSION_SECRET="change-me-session-min-32-chars"

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Server-side Next.js rewrites — production install sets loopback + port
INTERNAL_API_URL="http://127.0.0.1:4000"
NEXT_PUBLIC_API_PORT=4000
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-nextauth-secret"

# ─── WebAuthn / Passkeys ─────────────────────────────────────────────────────
# WEBAUTHN_RP_ID must be a valid domain — bare IPs are not allowed by the WebAuthn spec.
#
# RP ID = the "site" the passkey is bound to; it must match the hostname in the browser URL (exact or parent domain).
# WEBAUTHN_ORIGIN should be the base URL users use (scheme + host + port). NEXTAUTH_URL + WEBAUTHN_EXTRA_ORIGINS
# are also considered when validating origins in the API.
#
# LAN: nip.io-style hostnames (e.g. 192-168-1-10.nip.io) encode your IP in DNS. They assume public DNS resolves the
# name to your host; if DNS is wrong or hijacked, passkey behaviour is undefined — prefer a real FQDN + HTTPS in
# production when you can.
#
# Production hardening: set both explicitly and optionally require at API startup (fails if missing in production):
# HOSTPANEL_WEBAUTHN_REQUIRE_EXPLICIT=true
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGIN="http://localhost:3000"
WEBAUTHN_RP_NAME="HostPanel"
# Optional: comma-separated list of additional allowed origins (e.g. if panel has multiple URLs)
WEBAUTHN_EXTRA_ORIGINS=""

# ─── OAuth ─────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── SSL / Let's Encrypt ────────────────────────────────────────────────────────
ACME_EMAIL="admin@example.com"
ACME_STAGING=false  # use true only for Let's Encrypt staging / testing

# ─── Integrations ──────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=""
SLACK_WEBHOOK_URL=""
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""

# ─── Web servers (API runs as non-root; use a directory that user can write) ───
# Default install uses /var/lib/hostpanel/nginx-sites + include in /etc/nginx/conf.d/
NGINX_SITES_DIR="/var/lib/hostpanel/nginx-sites"

# ─── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@localhost"
ADMIN_PASSWORD="change-me"
