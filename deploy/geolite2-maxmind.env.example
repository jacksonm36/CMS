# Copy to /etc/hostpanel/geolite2-maxmind.env (root, chmod 600). Cron uses
# scripts/run-geolite2-download-with-env-file.sh — only the three variables below are read (no shell sourcing).
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
# Optional — default /var/lib/GeoIP
# MAXMIND_GEOLITE2_DIR=/var/lib/GeoIP
