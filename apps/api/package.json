{
  "name": "@hostpanel/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "sh -c 'tsc -p tsconfig.build.json --pretty false || test -f dist/index.js'",
    "start": "node --import tsx dist/index.js",
    "typecheck": "tsc --noEmit",
    "test:files": "tsx --test src/modules/sites/files.guard.test.ts src/middleware/waf.test.ts src/lib/security-env.cron.test.ts src/modules/auth/webauthn-rp.test.ts",
    "db:generate": "cd ../../packages/db && npm run db:generate",
    "db:migrate": "cd ../../packages/db && npm run db:migrate",
    "db:seed": "cd ../../packages/db && npm run db:seed"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.1",
    "@hostpanel/db": "*",
    "@hostpanel/types": "*",
    "@simplewebauthn/server": "^13.3.0",
    "acme-client": "^5.4.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "node-pty": "^1.1.0",
    "otplib": "^12.0.1",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "systeminformation": "^5.23.5",
    "tsx": "^4.19.2",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
